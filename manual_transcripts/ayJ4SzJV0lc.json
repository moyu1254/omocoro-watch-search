      "text": "SNA"
    },
    {
      "start": 826.32,
      "duration": 2.519,
      "text": "戦略とかめっちゃやってる感じでもないし。"
    },
    {
      "start": 828.48,
      "duration": 3.359,
      "text": "うん。"
    },
    {
      "start": 828.839,
      "duration": 3.0,
      "text": "おい、これ見るとやっぱでもホームページなのかもな結局は。"
    },
    {
      "start": 833.04,
      "duration": 1.12,
      "text": "これからは"
