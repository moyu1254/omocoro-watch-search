      "start": 453.36,
      "duration": 3.16,
      "text": "うん。"
    },
    {
      "start": 453.68,
      "duration": 4.32,
      "text": "もう毛こタ麺中本を食べ続けてる。"
    },
    {
      "start": 456.52,
      "duration": 2.799,
      "text": "あ、すげえ。"
    },
    {
      "start": 458.0,
      "duration": 3.12,
      "text": "で、もうなんか週10"
    },
    {
      "start": 459.319,
      "duration": 3.121,
      "text": "回ぐらい食べることもあるみたいな。"
    },
    {
      "start": 461.12,
      "duration": 3.0,
      "text": "え、週10回?"
    },
    {
      "start": 462.44,
      "duration": 3.759,
      "text": "毎日2回ずつ食う"
    },
    {
      "start": 464.12,
      "duration": 4.519,
      "text": "みたいな時もあるみたいな"
    },
    {
      "start": 466.199,
      "duration": 5.321,
      "text": "ことを、ま、インタビュー答えていて、"
    },
    {
      "start": 468.639,
      "duration": 5.881,
      "text": "まあ、なんかなぜっていうのと"
    },
    {
      "start": 471.52,
      "duration": 3.0,
      "text": "なんかそのちょすごすぎるからどうしたっていうようなのをずっとインタビューで聞いて全"
