    {
      "start": 926.24,
      "duration": 3.0,
      "text": "藤そばでもそうだな。全然"
    },
    {
      "start": 928.12,
      "duration": 3.24,
      "text": "い、藤そばいいんじゃない?"
    },
    {
      "start": 929.24,
      "duration": 3.519,
      "text": "藤そばファンはいそうですね。いるよね。"
    },
    {
      "start": 931.36,
      "duration": 3.52,
      "text": "俺渋ばの方が好きです。"
    },
    {
      "start": 932.759,
      "duration": 4.241,
      "text": "あ、じゃ、渋の道をそば。"
    },
    {
      "start": 934.88,
      "duration": 4.959,
      "text": "しぶそばってでも全然店舗なくないですか?"
    },
    {
      "start": 937.0,
      "duration": 4.399,
      "text": "うん。意外とやっぱ東横線の民じゃないと知らないですか?"
    },
    {
      "start": 939.839,
      "duration": 3.041,
      "text": "そうすよね。あ、"
    },
    {
      "start": 941.399,
      "duration": 4.481,
      "text": "渋ぶそば美味しいよな。"
    },
    {
      "start": 942.88,
      "duration": 3.0,
      "text": "おしい。うん。なんかでもそういう庭園店のここみたいなやつはいいよね。見ちゃうよね。なんかでもわか"
    },
    {
      "start": 951.56,
      "duration": 4.079,
      "text": "確かに"
    },
    {
      "start": 952.639,
      "duration": 3.0,
      "text": "意外なところを行きたいって気持ちはありますけどね。なんかサイゼリアとかうん。うん。"
    },
    {
      "start": 957.56,
      "duration": 3.0,
      "text": "なんかね、結構みんな好きというか語られちょっとやめといた方がいいのか。"
    },
    {
      "start": 963.36,
      "duration": 3.0,
      "text": "うん。サイゼリアは結構でもあるよね。そのこういう食べ方をしようみたいなね。なぜかイタリアの人がなんかこう言ってたりする。"
    },
    {
      "start": 972.12,
      "duration": 3.36,
      "text": "はいはいはい。な"
    },
    {
      "start": 973.12,
      "duration": 3.8,
      "text": "んだろう。私オリーブの丘が好きです。"
    },
    {
      "start": 975.48,
      "duration": 4.44,
      "text": "あ、はいはいはい。"
    },
    {
      "start": 976.92,
      "duration": 3.0,
      "text": "あの前哨かな?浜寿とかのグループがやってる"
    },
    {
      "start": 980.16,
      "duration": 3.0,
      "text": "イタリアンチェーンのオリーブの丘っていうのが最近ちょっと増え始めていて。"
    },
    {
      "start": 983.959,
      "duration": 3.921,
      "text": "あ、そうなんだ。"
    },
    {
      "start": 984.88,
      "duration": 3.0,
      "text": "そこはかなり美味しいし安いし"
    },
    {
      "start": 988.199,
      "duration": 2.041,
      "text": "なんかメニューも豊富で"
    },
    {
      "start": 989.72,
      "duration": 1.44,
      "text": "はい。"
    },
    {
      "start": 990.24,
      "duration": 1.519,
      "text": "いいんですけど"
    },
    {
      "start": 991.16,
      "duration": 2.56,
      "text": "うん。"
    },
    {
      "start": 991.759,
      "duration": 4.961,
      "text": "なんか私より"
    },
    {
      "start": 993.72,
      "duration": 3.0,
      "text": "オニアさんの方がオリーブが好きでうん。"
    },
    {
      "start": 996.959,
      "duration": 3.0,
      "text": "なんかプラチナカー員じゃないけど通いまくることで得られる"
    },
    {
      "start": 1001.12,
      "duration": 3.399,
      "text": "1番最高の称号を手にしてて。"
    },
    {
      "start": 1003.8,
      "duration": 1.0,
      "text": "あ、そんなんあんの?"
    },
    {
      "start": 1004.519,
      "duration": 3.281,
      "text": "はい。"
    },
    {
      "start": 1004.8,
      "duration": 3.0,
      "text": "なんかちょっとどうでも良くなっちゃった。あ、自分より熱量な"
    },
    {
      "start": 1008.759,
      "duration": 4.281,
      "text": "自分だけのオリーブかと思ってたら"
    },
    {
      "start": 1011.0,
      "duration": 3.519,
      "text": "ああ、オニアのオリーブだったんだ。"
    },
    {
      "start": 1013.04,
      "duration": 4.479,
      "text": "抱き尽くされてた。"
    },
    {
      "start": 1014.519,
      "duration": 3.0,
      "text": "ああ。じゃ、オニアがトごさんみたいなも"
    },
    {
      "start": 1018.92,
      "duration": 3.0,
      "text": "オリーブの丘に毎日行く人にの道"
    },
    {
      "start": 1022.279,
      "duration": 2.28,
      "text": "オニアはできそうだよな。"
    },
    {
      "start": 1023.68,
      "duration": 1.8,
      "text": "なんか行けそうだよね。"
    },
    {
      "start": 1024.559,
      "duration": 3.64,
      "text": "確かに。ああ、"
    },
    {
      "start": 1025.48,
      "duration": 5.719,
      "text": "なんか鬼さんの必要さって怖いんだよ。"
    },
    {
      "start": 1028.199,
      "duration": 3.0,
      "text": "ああ。いや、確かにそう。一時期パトカーの写真を集めて"
    },
    {
      "start": 1034.559,
      "duration": 1.64,
      "text": "本当に怖い。"
    },
    {
      "start": 1035.559,
      "duration": 1.48,
      "text": "危ないやつ。"
    },
    {
      "start": 1036.199,
      "duration": 3.84,
      "text": "本当に怖い。な"
    },
    {
      "start": 1037.039,
      "duration": 3.0,
      "text": "んか一緒に歩いたりしててパトカー見つけると必ずね記録してるんですよ。"
    },
    {
      "start": 1041.28,
      "duration": 3.759,
      "text": "うわ、なんか"
    },
    {
      "start": 1042.039,
      "duration": 3.0,
      "text": "なんかさ、結構怒られないのかな?なんかその装備とかを取ろうとしてるとか思われた。"
    },
    {
      "start": 1046.959,
      "duration": 2.361,
      "text": "でもマニアとかもいるし"
    },
    {
      "start": 1048.199,
      "duration": 4.121,
      "text": "いるから。ま、いいのか。"
    },
    {
      "start": 1049.32,
      "duration": 3.0,
      "text": "公共の財だからいいんじゃないですか。パトカーは。あ、いや、記録中なんだ結はね。"
    },
    {
      "start": 1054.559,
      "duration": 3.681,
      "text": "うん。"
    },
    {
      "start": 1055.24,
      "duration": 3.0,
      "text": "レモンの記事とかも出してましたけどもちょっとなんかさ、その気合い入ったホームページあって"
    },
    {
      "start": 1063.64,
      "duration": 4.32,
      "text": "ああ、確かにそうだね。確か"
    },
    {
      "start": 1064.96,
      "duration": 3.0,
      "text": "なんかあのエタメにしないぞっていう着いを逆に感じた気がした。なんかそのもっとふざけてもいいの"
    },
    {
      "start": 1073.32,
      "duration": 3.0,
      "text": "いいはずだったと思う。ふざけがないっていうのがなんかこう"
    },
    {
      "start": 1078.44,
      "duration": 3.0,
      "text": "見せたかったんだろうなっていう。あ、それはありますね。"
    },
    {
      "start": 1081.52,
      "duration": 3.0,
      "text": "やっぱもう本当にふざけようと思ったらやっぱ漬けとごさんみたいな方になるっていうのが"
    },
    {
      "start": 1088.76,
      "duration": 3.24,
      "text": "なんか正しい道なのかも。"
    },
    {
      "start": 1090.24,
      "duration": 4.76,
      "text": "いや、ふざけてないすよ。ず"
    },
    {
      "start": 1092.0,
      "duration": 3.0,
      "text": "いや、ふざけてないんだけどそのマジなんですよ。どこまで裏らない。マじすぎるっていうのが本当は一番面白い。"
    },
    {
      "start": 1101.32,
      "duration": 4.16,
      "text": "ふざけを超えた。え、"
    },
    {
      "start": 1103.0,
      "duration": 3.2,
      "text": "マジの顔がいい。マじすぎるっていう。"
    },
    {
      "start": 1105.48,
      "duration": 3.72,
      "text": "うん。"
    },
    {
      "start": 1106.2,
      "duration": 3.0,
      "text": "なんかオニアもその出力を絞ってオリーブの丘にオリーブの丘番漬けとごさんを目指したら"
    },
    {
      "start": 1112.679,
      "duration": 3.281,
      "text": "ね"
    },
    {
      "start": 1112.96,
      "duration": 3.0,
      "text": "うん。漬け鬼さんっていう人になって"
    },
    {
      "start": 1116.4,
      "duration": 3.0,
      "text": "確かあ、藤そば原理主義っていうサイトがやっぱあるわ。"
    },
    {
      "start": 1120.12,
      "duration": 2.799,
      "text": "やっぱいるんだよね。チェーン店に"
    },
    {
      "start": 1122.4,
      "duration": 1.639,
      "text": "1人は"
    },
    {
      "start": 1122.919,
      "duration": 4.12,
      "text": "い悔しい。"
    },
    {
      "start": 1124.039,
      "duration": 3.0,
      "text": "なんか開いてるチェーン店ちょっと一覧にしてください。今から"
    },
    {
      "start": 1127.08,
      "duration": 3.0,
      "text": "え、なんかちょうどいいところをね、見据えたいけどな。"
    },
    {
      "start": 1131.0,
      "duration": 3.72,
      "text": "そう。"
    },
    {
      "start": 1131.72,
      "duration": 3.0,
      "text": "さん的な人がいないチェーン店を今から確"
    },
    {
      "start": 1135.4,
      "duration": 4.36,
      "text": "誰も好きじゃないチェーン店募集"
    },
    {
      "start": 1137.919,
      "duration": 2.561,
      "text": "それをコロライターに配ってこう"
    },
    {
      "start": 1139.76,
      "duration": 2.76,
      "text": "1個1個"
    },
    {
      "start": 1140.48,
      "duration": 3.76,
      "text": "お前はこれを食え確かに"
    },
    {
      "start": 1142.52,
      "duration": 3.279,
      "text": "手札して"
    },
    {
      "start": 1144.24,
      "duration": 2.72,
      "text": "はい"
    },
    {
      "start": 1145.799,
      "duration": 4.161,
      "text": "集中で食えよ"
    },
    {
      "start": 1146.96,
      "duration": 3.0,
      "text": "運命だと思えって言って配ってったらみんな有名になっていくから"
    },
    {
      "start": 1151.76,
      "duration": 3.24,
      "text": "銀ダコとかって意外とさ"
    },
    {
      "start": 1154.28,
      "duration": 3.72,
      "text": "いるか"
    },
    {
      "start": 1155.0,
      "duration": 3.0,
      "text": "全然いるじゃ数が多いっていうのがちょっとネックだよねす"
    },
    {
      "start": 1161.039,
      "duration": 1.52,
      "text": "そうすよね。"
    },
    {
      "start": 1161.799,
      "duration": 3.76,
      "text": "うん。"
    },
    {
      "start": 1162.559,
      "duration": 3.0,
      "text": "そんなになんかメニューもあんまないというか、"
    },
    {
      "start": 1165.799,
      "duration": 3.0,
      "text": "パターンはないっていうのは銀ダコマニアのページはないです。"
    },
    {
      "start": 1169.0,
      "duration": 4.76,
      "text": "ああ、ここだ。"
    },
    {
      "start": 1170.76,
      "duration": 3.0,
      "text": "そういうところだろうな。なんかスポット抜け落ちてる。"
    },
    {
      "start": 1174.24,
      "duration": 2.919,
      "text": "なんかあるんですよ"
    },
    {
      "start": 1175.24,
      "duration": 3.439,
      "text": "ね。前焼きそばマニアみたいな。"
    },
    {
      "start": 1177.159,
      "duration": 2.921,
      "text": "あ、ましたね。と"
    },
    {
      "start": 1178.679,
      "duration": 2.721,
      "text": "そこもやっぱ抑えられてるのか。"
    },
    {
      "start": 1180.08,
      "duration": 4.0,
      "text": "焼きそばは強いよな。"
    },
    {
      "start": 1181.4,
      "duration": 3.6,
      "text": "強いね。これは話聞きたいもんね。"
    },
    {
      "start": 1184.08,
      "duration": 3.92,
      "text": "うん。"
    },
    {
      "start": 1185.0,
      "duration": 3.0,
      "text": "たこ焼きマニアに銀ダコマニアは吸収されちゃうのもちょっと尺ですね。"
    },
    {
      "start": 1188.88,
      "duration": 3.0,
      "text": "ああ、確かにだいのを色々考えてみんなで戦略ていけばうん。"
    },
    {
      "start": 1195.72,
      "duration": 3.0,
      "text": "いや、それとはやっぱ違うんですよ。この漬けさんの本気度っていうの。"
    },
    {
      "start": 1200.48,
      "duration": 5.8,
      "text": "ただただ熱確かにそう"
    },
    {
      "start": 1203.28,
      "duration": 3.0,
      "text": "やっぱ降りてくるのを待つしかないんだ。やっぱ指令が天からまだ心に暇のある生物だから。"
    },
    {
      "start": 1210.36,
      "duration": 3.0,
      "text": "あ、規制だ。命令が来てないんだ。寄点行っただろう。"
    },
    {
      "start": 1215.919,
      "duration": 3.0,
      "text": "いや、行けなくて悔しくて言って行ったのかなと思った。"
    },
    {
      "start": 1221.48,
      "duration": 1.319,
      "text": "行きたかった。"
    },
    {
      "start": 1222.36,
      "duration": 1.64,
      "text": "うん。"
    },
    {
      "start": 1222.799,
      "duration": 3.12,
      "text": "まだやってますからね。"
    },
    {
      "start": 1224.0,
      "duration": 4.799,
      "text": "さっき読み返していいなと思ったんですね。"
    },
    {
      "start": 1225.919,
      "duration": 4.481,
      "text": "ね。じゃあね、今日の結論は"
    },
    {
      "start": 1228.799,
      "duration": 4.601,
      "text": "規制中は面白いということです。"
    },
    {
      "start": 1230.4,
      "duration": 3.0,
      "text": "はい。はい。でももうこれみんな言ってるからやめよう。棚夕端の国の話を。"
    },
    {
      "start": 1234.64,
      "duration": 2.56,
      "text": "棚のそうだ。"
    },
    {
      "start": 1236.36,
      "duration": 1.439,
      "text": "そっち"
    },
    {
      "start": 1237.2,
      "duration": 2.56,
      "text": "ではまり"
    },
    {
      "start": 1237.799,
      "duration": 2.081,
      "text": "そっちの漬け投稿になるか。"
    },
    {
      "start": 1239.76,
      "duration": 3.12,
      "text": "1"
    },
    {
      "start": 1239.88,
      "duration": 3.0,
      "text": "人も規も読んだことないけど棚夕端の国だけ。"
    },
    {
      "start": 1243.88,
      "duration": 4.12,
      "text": "バタのなんかあのなんか空間が開くみたいな。"
    },
    {
      "start": 1246.72,
      "duration": 2.439,
      "text": "そうね。超能力"
    },
    {
      "start": 1248.0,
      "duration": 2.12,
      "text": "パってなる。"
    },
    {
      "start": 1249.159,
      "duration": 3.961,
      "text": "あれだから1"
    },
    {
      "start": 1250.12,
      "duration": 3.0,
      "text": "個も覚えてないかも俺。ストーリーだ。面白かった。記憶。"
    },
    {
      "start": 1253.44,
      "duration": 3.44,
      "text": "そう。面白かったんだよね。4"
    },
    {
      "start": 1254.84,
      "duration": 5.04,
      "text": "個ぐらいだよね。全短いんですよ。"
    },
    {
      "start": 1256.88,
      "duration": 3.0,
      "text": "なんか民族学的な感じの話だったな。ああ。棚夕端の国じゃ来週会難しいな。いいけど。"
    },
    {
      "start": 1267.96,
      "duration": 2.719,
      "text": "面白いですからね。"
    },
    {
      "start": 1268.96,
      "duration": 4.199,
      "text": "ね。というわけで、"
    },
    {
      "start": 1270.679,
      "duration": 4.041,
      "text": "みんなもね、司令が来たら"
    },
    {
      "start": 1273.159,
      "duration": 1.841,
      "text": "それに従ってみてください。"
    },
    {
      "start": 1274.72,
      "duration": 2.8,
      "text": "はい。"
    },
    {
      "start": 1275.0,
      "duration": 5.08,
      "text": "地球の誰かがふとを持ったというね。"
    },
    {
      "start": 1277.52,
      "duration": 5.56,
      "text": "というわけで、今週はこの辺でありがとうございました。"
    },
    {
      "start": 1280.08,
      "duration": 3.0,
      "text": "ありがとうございました。"
    }
  ]
}
