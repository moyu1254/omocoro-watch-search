      "start": 817.88,
      "duration": 3.0,
      "text": "でもなんか社長とも多分繋がりあるから得てやってくださいよみたいな感じなのかね。"
    },
    {
      "start": 823.68,
      "duration": 2.64,
      "text": "確かに中本もまそういうね"
    },
