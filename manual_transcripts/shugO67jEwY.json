    },
    {
      "start": 784.839,
      "duration": 4.321,
      "text": "すごい誰かはもうやっちゃうんだもんね。"
    },
    {
      "start": 786.88,
      "duration": 2.92,
      "text": "そうやっぱタイミーも危ないんだ。"
    },
    {
      "start": 789.16,
      "duration": 3.64,
      "text": "うわあ。"
    },
    {
      "start": 789.8,
      "duration": 3.0,
      "text": "ああ、だからもうこの便利になったと思いきやもうこういう抜け道のやつがたくさん生まれちゃうっていうね。"
    },
    {
      "start": 797.279,
      "duration": 2.36,
      "text": "そう、そう。"
    },
    {
      "start": 797.639,
      "duration": 5.0,
      "text": "だから1人の店長の中に4"
    },
    {
      "start": 799.639,
      "duration": 3.0,
      "text": "人のタイミーが入ってこともできちゃう。"
    },
    {
      "start": 803.72,
      "duration": 4.96,
      "text": "なんでまた寄生獣の話"
    },
    {
      "start": 806.32,
      "duration": 2.639,
      "text": "最近規獣の話ばっかして"
    },
    {
      "start": 808.68,
      "duration": 2.32,
      "text": "4"
    },
    {
      "start": 808.959,
      "duration": 4.24,
      "text": "対ミと同じ4対"
    },
    {
      "start": 811.0,
      "duration": 5.48,
      "text": "こいつ1人の中に"
    },
    {
      "start": 813.199,
      "duration": 5.841,
      "text": "4対"
    },
    {
      "start": 816.48,
      "duration": 5.56,
      "text": "こういうこそういうこと可能になってし"
    },
    {
      "start": 819.04,
      "duration": 3.0,
      "text": "確かに寄生理論で言ったら別にいいもんな"
    },
    {
      "start": 822.16,
      "duration": 3.0,
      "text": "すごいねすごいなんかすごいわないなも本当に"
    },
    {
      "start": 828.16,
      "duration": 4.479,
      "text": "ああすごい"
    },
    {
      "start": 829.639,
      "duration": 3.0,
      "text": "いやでも最初に気づいた時やっぱ震え"
    },
    {
      "start": 832.959,
      "duration": 2.761,
      "text": "たんでしょうね。"
    },
    {
      "start": 834.12,
      "duration": 4.6,
      "text": "これは店長がね、"
    },
    {
      "start": 835.72,
      "duration": 3.0,
      "text": "できてしまうんじゃないか。あ、いけるなみたいな。"
    },
    {
      "start": 838.8,
      "duration": 4.479,
      "text": "俺が2人になれば"
    },
    {
      "start": 840.399,
      "duration": 3.641,
      "text": "すごいしたらもう年収2倍ですから。"
    },
    {
      "start": 843.279,
      "duration": 3.761,
      "text": "そうだね。"
    },
    {
      "start": 844.04,
      "duration": 3.0,
      "text": "うん。こんな簡単なことがあったんだっていう。俺もごめんなさい。今日から"
    },
    {
      "start": 848.88,
      "duration": 3.16,
      "text": "2倍働"
    },
    {
      "start": 852.6,
      "duration": 1.76,
      "text": "2倍になる。2"
    },
    {
      "start": 853.48,
      "duration": 3.88,
      "text": "倍に"
    },
    {
      "start": 854.36,
      "duration": 3.0,
      "text": "ああ、でもそういう宣言ができる制度があったら面白いけどな。"
    },
    {
      "start": 857.88,
      "duration": 3.319,
      "text": "あ、"
    },
    {
      "start": 858.199,
      "duration": 3.0,
      "text": "働いてるとでいや、もっと働きたいです人もいるわけじゃ。確かに。はい。はい。はい。うん。"
    },
    {
      "start": 863.68,
      "duration": 5.24,
      "text": "もうじゃ、今月から2倍で"
    },
    {
      "start": 865.92,
      "duration": 3.0,
      "text": "行けるんでていう人がいたらなんか会社としては"
    },
    {
      "start": 869.36,
      "duration": 3.12,
      "text": "おお"
    },
    {
      "start": 870.399,
      "duration": 3.721,
      "text": "やってみたいな"
    },
    {
      "start": 872.48,
      "duration": 4.08,
      "text": "感じにはなりそうだけど。"
    },
    {
      "start": 874.12,
      "duration": 6.0,
      "text": "関心なことではあるよね。そんだけやる気が。"
    },
    {
      "start": 876.56,
      "duration": 6.6,
      "text": "実際その人を1人雇うより同じ人が"
    },
    {
      "start": 880.12,
      "duration": 5.48,
      "text": "2倍働いてくれた方がその"
    },
    {
      "start": 883.16,
      "duration": 3.0,
      "text": "保険とか考えたらお得ではあるんですよ。"
    },
    {
      "start": 885.6,
      "duration": 3.56,
      "text": "そうだよ。"
    },
    {
      "start": 886.16,
      "duration": 3.0,
      "text": "だからめっちゃブラックなところとかでなんで残業でその人増やさないかって言われたらやっぱそういう"
    },
    {
      "start": 891.959,
      "duration": 2.8,
      "text": "からクリもあったりするんで"
    },
    {
      "start": 893.92,
      "duration": 1.32,
      "text": "2倍2"
    },
    {
      "start": 894.759,
      "duration": 1.961,
      "text": "倍2"
    },
    {
      "start": 895.24,
      "duration": 2.8,
      "text": "倍宣言制度"
    },
    {
      "start": 896.72,
      "duration": 4.32,
      "text": "うわあすごい"
    },
    {
      "start": 898.04,
      "duration": 3.0,
      "text": "すごい健二次郎入社っていうのもありえる別の人格なんで"
    },
    {
      "start": 903.16,
      "duration": 3.44,
      "text": "やっぱりそこは別人格"
    },
    {
      "start": 904.48,
      "duration": 5.12,
      "text": "別人を1人作るんだあ"
    },
    {
      "start": 906.6,
      "duration": 3.0,
      "text": "ま期にはバリバリ触れてるけど"
    },
    {
      "start": 910.0,
      "duration": 1.839,
      "text": "やっぱ"
    },
    {
      "start": 910.44,
      "duration": 4.399,
      "text": "そういうのがあっても"
    },
    {
      "start": 911.839,
      "duration": 3.0,
      "text": "ああの半分を別人として働い"
    },
    {
      "start": 915.959,
      "duration": 5.841,
      "text": "で、2人分をらってことはできんのか。"
    },
    {
      "start": 918.8,
      "duration": 3.0,
      "text": "それ別にだって別名義で働いてるだけじゃ。その何の意味もない。"
    },
    {
      "start": 923.56,
      "duration": 4.92,
      "text": "そう。半にはなんの?"
    },
    {
      "start": 925.48,
      "duration": 3.0,
      "text": "なんか双子とか絡ませたらこれうまさらに発展できる。すげえ。双子タイミートリック。双タイミートリックね。"
    },
    {
      "start": 932.519,
      "duration": 5.201,
      "text": "ああ、これどうなる?"
    },
    {
      "start": 934.72,
      "duration": 3.0,
      "text": "これはじゃあ恐れにちょっと執筆してもらう。"
    },
    {
      "start": 937.959,
      "duration": 4.12,
      "text": "確かに"
    },
    {
      "start": 939.079,
      "duration": 3.0,
      "text": "タイミステリー来るでしょうね。"
    },
    {
      "start": 942.639,
      "duration": 4.32,
      "text": "タイミーミステリー"
    },
    {
      "start": 943.959,
      "duration": 3.0,
      "text": "なんかうまいことやったらすごいことですごいことできそうだよなっていう人がやっぱいっぱい生まれこれはだからないんでもうみんなちゃんと真面目に真面目に働こうというにタイミ"
    },
    {
      "start": 956.92,
      "duration": 3.0,
      "text": "バれなかったら増えてた可能性が全然あるからね。"
    },
    {
      "start": 960.04,
      "duration": 3.719,
      "text": "そうだよね。"
    },
    {
      "start": 960.8,
      "duration": 4.12,
      "text": "自分をまたもうちょっと自分雇おうかなみたいな。"
    },
    {
      "start": 963.759,
      "duration": 4.161,
      "text": "確かにあと3"
    },
    {
      "start": 964.92,
      "duration": 3.0,
      "text": "人行けるかみたいな思ペになるぞ。それずっと"
    },
    {
      "start": 968.319,
      "duration": 5.721,
      "text": "思えば5倍働いてるもん。"
    },
    {
      "start": 971.04,
      "duration": 3.0,
      "text": "確かにどんどん甘くなってくる。そういうが"
    },
    {
      "start": 974.68,
      "duration": 1.959,
      "text": "自己評価"
    },
    {
      "start": 976.319,
      "duration": 1.88,
      "text": "すごい。"
    },
    {
      "start": 976.639,
      "duration": 2.961,
      "text": "俺ってバイト5人分だよな。"
    },
    {
      "start": 978.199,
      "duration": 2.041,
      "text": "いけるよな、これみたいな。"
    },
    {
      "start": 979.6,
      "duration": 3.64,
      "text": "うん。"
    },
    {
      "start": 980.24,
      "duration": 3.0,
      "text": "そういう正当化もしてっていきちゃうからね。気をつけないとということで。"
    },
    {
      "start": 986.0,
      "duration": 3.0,
      "text": "はい。え、ね、ニュースはね、ちょっと以上なんですけど、ま、ちょっと告知というかお知らせがありまして、"
    },
    {
      "start": 991.88,
      "duration": 2.519,
      "text": "あの、1月にやったおコロウォッチの、"
    },
    {
      "start": 994.079,
      "duration": 1.12,
      "text": "あ、"
    },
    {
      "start": 994.399,
      "duration": 1.321,
      "text": "イベント"
    },
    {
      "start": 995.199,
      "duration": 3.521,
      "text": "出た。"
    },
    {
      "start": 995.72,
      "duration": 3.0,
      "text": "不ほどニュースはもうええでしょう。スペシャルだっけ?"
    },
    {
      "start": 999.0,
      "duration": 5.72,
      "text": "そうだわ。ひどいタイトルありましたね。"
    },
    {
      "start": 1001.72,
      "duration": 3.0,
      "text": "ね、あれが、え、ブルーレイ化されたということで、"
    },
    {
      "start": 1004.8,
      "duration": 1.88,
      "text": "あ、ブルーレイに"
    },
    {
      "start": 1005.72,
      "duration": 3.0,
      "text": "なったんですね。"
    },
    {
      "start": 1006.68,
      "duration": 2.32,
      "text": "はい。6月30日の火曜日。"
    },
    {
      "start": 1008.72,
      "duration": 1.919,
      "text": "はい。あ"
    },
    {
      "start": 1009.0,
      "duration": 2.04,
      "text": "あ、もう来週は"
    },
    {
      "start": 1010.639,
      "duration": 3.401,
      "text": "夜7"
    },
    {
      "start": 1011.04,
      "duration": 3.0,
      "text": "時から発売開始ということで、こちらの通常のね、ブルーレイと特走版"
    },
    {
      "start": 1016.759,
      "duration": 2.0,
      "text": "うん。"
    },
    {
      "start": 1017.24,
      "duration": 3.159,
      "text": "ブルーレイって言って色々ね、"
    },
    {
      "start": 1018.759,
      "duration": 4.0,
      "text": "なんかね、おまけがね、ついてんですよ。"
    },
    {
      "start": 1020.399,
      "duration": 3.041,
      "text": "そう。イベントチケット風のこうね。"
    },
    {
      "start": 1022.759,
      "duration": 1.2,
      "text": "うん。うん。"
    },
    {
      "start": 1023.44,
      "duration": 1.399,
      "text": "やつだっ。"
    },
    {
      "start": 1023.959,
      "duration": 1.321,
      "text": "はい。はい。はい。"
    },
    {
      "start": 1024.839,
      "duration": 2.12,
      "text": "うん。"
    },
    {
      "start": 1025.28,
      "duration": 3.679,
      "text": "なんかね、いい素材でした。ツルツル。ステ"
    },
    {
      "start": 1026.959,
      "duration": 4.401,
      "text": "ステッカーテー。"
    },
    {
      "start": 1028.959,
      "duration": 3.12,
      "text": "うん。あとなんとアクリルスタンドが"
    },
    {
      "start": 1031.36,
      "duration": 1.16,
      "text": "うん。そう"
    },
    {
      "start": 1032.079,
      "duration": 1.801,
      "text": "そう"
    },
    {
      "start": 1032.52,
      "duration": 2.6,
      "text": "ついてまして。"
    },
    {
      "start": 1033.88,
      "duration": 1.799,
      "text": "空っぽのタクシー。"
    },
    {
      "start": 1035.12,
      "duration": 3.559,
      "text": "そう"
    },
    {
      "start": 1035.679,
      "duration": 3.0,
      "text": "そう。イベントをご覧になった方はご存知だと思うんですけど空っぽのタクシーがうん。"
    },
    {
      "start": 1040.559,
      "duration": 3.24,
      "text": "ね、あのイベントでは重要なキー"
    },
    {
      "start": 1042.76,
      "duration": 3.159,
      "text": "非常にキー"
    },
    {
      "start": 1043.799,
      "duration": 3.88,
      "text": "あれがまさかアクスタするとね。"
    },
    {
      "start": 1045.919,
      "duration": 4.76,
      "text": "っぽのタクシーのアクスタはなかなか。"
    },
    {
      "start": 1047.679,
      "duration": 3.0,
      "text": "そう。これは熱いんで。ここでしかゲットできないんでね。"
    },
    {
      "start": 1050.76,
      "duration": 3.0,
      "text": "で、あの冒頭と最後にやった寸のあの台本の複製がも"
    },
    {
      "start": 1056.039,
      "duration": 3.481,
      "text": "うん。すごい"
    },
    {
      "start": 1057.0,
      "duration": 3.28,
      "text": "台本あったんだあれ。そう。"
    },
    {
      "start": 1059.52,
      "duration": 1.36,
      "text": "あ、そうなの?"
    },
    {
      "start": 1060.28,
      "duration": 0.96,
      "text": "お、"
    },
    {
      "start": 1060.88,
      "duration": 3.36,
      "text": "そんな"
    },
    {
      "start": 1061.24,
      "duration": 3.0,
      "text": "演技をするにあたってのなんかそういうもろのみたいな。"
    },
    {
      "start": 1065.039,
      "duration": 4.52,
      "text": "あ、そんな一生懸命やってた。"
    },
    {
      "start": 1066.559,
      "duration": 3.0,
      "text": "終わってからそれっぽく書いてある。"
    },
    {
      "start": 1069.76,
      "duration": 3.0,
      "text": "ま、そうだろうな。うん。ない。もうここでしか手に入らない。"
    },
    {
      "start": 1075.6,
      "duration": 3.0,
      "text": "そう。で、こちら是ひ特走版の方はい。に入ってるんで、"
    },
    {
      "start": 1079.52,
      "duration": 2.639,
      "text": "え、あと、え、デジタル版"
    },
    {
      "start": 1081.64,
      "duration": 3.519,
      "text": "あ、なるほどね。"
    },
    {
      "start": 1082.159,
      "duration": 3.0,
      "text": "もありますんで、ま、別に物いらねえよっていう方はそちらを貼っていただいて、あとね、得典映像とかもたっぷり入っていっぱい入ってます。"
    },
    {
      "start": 1089.2,
      "duration": 3.0,
      "text": "じゃあね、物売るってレベルじゃねえよという人はこちらもお買い求でございなんで、なんでなんか今ふと思いついたと思いついたこと言えばいいってもんじゃないぞ。"
    },
    {
      "start": 1102.0,
      "duration": 5.799,
      "text": "特定映像がね、特定映像させてよ。"
    },
    {
      "start": 1104.799,
      "duration": 3.0,
      "text": "そう、あの、なんかイベント打ち上げみたいな"
    },
    {
      "start": 1107.88,
      "duration": 3.64,
      "text": "はいはいはい。"
    },
    {
      "start": 1108.799,
      "duration": 3.321,
      "text": "感じでこう3人でね、お酒を飲みながら"
    },
    {
      "start": 1111.52,
      "duration": 1.88,
      "text": "うん。うん。うん。"
    },
    {
      "start": 1112.12,
      "duration": 2.2,
      "text": "話す会があったんですけど。"
    },
    {
      "start": 1113.4,
      "duration": 3.2,
      "text": "あ、あったりとかね。"
    },
    {
      "start": 1114.32,
      "duration": 3.52,
      "text": "うん。あれがね、後の"
    },
    {
      "start": 1116.6,
      "duration": 4.24,
      "text": "あ、そうだ、そうだ。それだ。"
    },
    {
      "start": 1117.84,
      "duration": 3.0,
      "text": "ちょっと説明ですけど、原宿引退式というイベントでね、原宿さんが泥水したあいつっていうのになるっていうのを、ま、取ってたんですけど、その撮影がそ、あいつ撮影の前がこの、おウォッチの"
    },
    {
      "start": 1132.24,
      "duration": 3.0,
      "text": "打ち上げ撮影だった。そうなんだ。で、その打ち上げでちょっともうあいつは花ぐらいね、出てるん始まってたんですよ。"
    },
    {
      "start": 1140.64,
      "duration": 3.64,
      "text": "出てんの?その時点で。"
    },
    {
      "start": 1142.32,
      "duration": 2.88,
      "text": "出て。そう。だからそれも収録されてるし。"
    },
    {
      "start": 1144.28,
      "duration": 2.32,
      "text": "あ、すごい。"
    },
    {
      "start": 1145.2,
      "duration": 2.599,
      "text": "あいつ全夜。"
    },
    {
      "start": 1146.6,
      "duration": 3.6,
      "text": "そう、そういうこと。"
    },
    {
      "start": 1147.799,
      "duration": 5.401,
      "text": "結構確かにあいつでした。僕も見ましたけど。"
    },
    {
      "start": 1150.2,
      "duration": 3.0,
      "text": "え、そう、そうなん。ま、ちょっとここもご確認いて。そうか。特定映像もついてるね。"
    },
    {
      "start": 1156.039,
      "duration": 3.601,
      "text": "そう。はい。で、あと何だっけ?"
    },
    {
      "start": 1157.919,
      "duration": 3.161,
      "text": "あの、あれだ。"
    },
    {
      "start": 1159.64,
      "duration": 2.8,
      "text": "アーマみ投げだ。"
    },
    {
      "start": 1161.08,
      "duration": 2.52,
      "text": "あ、確かに名作。"
    },
    {
      "start": 1162.44,
      "duration": 1.68,
      "text": "あ、アーバみ投げね。"
    },
    {
      "start": 1163.6,
      "duration": 3.52,
      "text": "うん。"
    },
    {
      "start": 1164.12,
      "duration": 3.0,
